[Unit]
Description=ICSAC Editorial System — community-request poller
Documentation=https://github.com/ICSAC/editorial-system
After=network-online.target
Wants=network-online.target

[Service]
Type=oneshot
User=icsac
WorkingDirectory=/opt/icsac/editorial-system
ExecStart=/usr/bin/python3 /opt/icsac/editorial-system/editorial_workflow.py poll
EnvironmentFile=/etc/icsac/editorial.env
TimeoutStartSec=900
StandardOutput=journal
StandardError=journal
NoNewPrivileges=true
ProtectSystem=strict
ProtectHome=read-only
ReadWritePaths=/opt/icsac/editorial-system /var/lib/icsac/site

[Install]
WantedBy=multi-user.target
